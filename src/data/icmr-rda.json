  "key_differences_from_global_standards": {
    "note": "Use this section for prompting Gemini or explaining differences to users",
    "differences": [
      {
        "nutrient": "Iron (menstruating women)",
        "icmr_2020": "21 mg/day",
        "who_global": "~20 mg/day",
        "us_rda": "18 mg/day",
        "reason": "High prevalence of anaemia in Indian women (>50% in some states). ICMR sets higher target."
      },
      {
        "nutrient": "Calories (sedentary adult female)",
        "icmr_2020": "1660 kcal/day (19-29 yrs)",
        "common_default": "2000 kcal/day",
        "reason": "Lower average body weight and BMR in Indian population vs Western reference populations."
      },
      {
        "nutrient": "Protein",
        "icmr_2020": "0.83 g/kg body weight — population average ~54g for males",
        "note": "Indian diets are predominantly cereal-based with lower bioavailability protein. ICMR accounts for mixed vegetarian diet."
      },
      {
        "nutrient": "Vitamin D",
        "icmr_2020": "600 IU (15 mcg)",
        "us_rda": "600 IU",
        "note": "Despite India's sun exposure, Vitamin D deficiency is paradoxically high due to indoor lifestyle, traditional clothing, melanin levels."
      },
      {
        "nutrient": "Calcium (elderly 60+)",
        "icmr_2020": "1200 mg/day",
        "who_global": "1000 mg/day",
        "reason": "Higher osteoporosis risk in Indian elderly, partly due to historically lower calcium intake."
      },
      {
        "nutrient": "Sodium",
        "icmr_2020": "2000 mg/day max",
        "who_global": "2000 mg/day",
        "note": "Indian diets routinely exceed 3000-4000mg/day. Extra caution warranted when flagging sodium in Indian context."
      }
    ]
  },

  "lookup_helper": {
    "usage": "Given user profile {age, gender, activity_level}, look up the correct RDA object. Fall back to 'sedentary' if activity unknown. Fall back to male/female 30-59 if age unknown for adult.",
    "age_bracket_mapping": {
      "1-3":   "children.1_to_3",
      "4-6":   "children.4_to_6",
      "7-9":   "children.7_to_9",
      "10-12": "children.boys_10_to_12 or girls_10_to_12",
      "13-15": "children.boys_13_to_15 or girls_13_to_15",
      "16-18": "children.boys_16_to_18 or girls_16_to_18",
      "19-29": "adults.male/female.19_to_29",
      "30-59": "adults.male/female.30_to_59",
      "60-69": "adults.male/female.60_to_69",
      "70+":   "adults.male/female.70_plus"
    }
